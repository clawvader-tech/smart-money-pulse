# Smart Money Pulse Monitor - Environment Variables
# Copy this to .env and fill in your values

# Nansen API (get from partnerships@nansen.ai)
NANSEN_API_KEY=your_nansen_api_key_here

# OpenRouter API (get from openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# fal.ai API (get from fal.ai)
FAL_KEY=your_fal_api_key_here

# OKX Wallet (optional - for live trading)
# OKX_WALLET_ADDRESS=your_wallet_address_here
